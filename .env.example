# Veyra Edge Service — environment configuration
# Copy this file to `.env` and adjust the values for your edge server.

# Local path of the SQLite database used for offline buffering of telemetry.
SQLITE_DB_PATH=veyra_edge.db

# Cloud backend API base URL — must include the /api/v1 prefix.
API_SYNC_URL=https://veyra-backend.redwave-e7e23e62.canadacentral.azurecontainerapps.io/api/v1

# Serial/network port reserved for a future non-HTTP device transport.
# Embedded devices using HTTP/Wi-Fi do not need this setting.
EDGE_DEVICE_PORT=

# Toggle cloud synchronization on/off.
CLOUD_SYNC_ENABLED=true

# HTTP timeout (seconds) for cloud sync requests.
CLOUD_SYNC_TIMEOUT=5

# Max unsynced measurements replayed to the cloud per background cycle.
CLOUD_SYNC_BATCH_SIZE=20

# Bootstrap the local device registry from a JSON file on first request.
# Copy nodes.seed.example.json to nodes.seed.json and align with firmware secrets.h.
NODE_SEED_ENABLED=true
NODE_SEED_PATH=nodes.seed.json

# Gateway identity at the cloud backend. MAC is detected at runtime (host NIC);
# set GATEWAY_MAC_ADDRESS only to override (Docker, multiple NICs, tests).
GATEWAY_DEVICE_ID=edge-local-001
GATEWAY_MAC_ADDRESS=
GATEWAY_DEVICE_TYPE=EDGE_GATEWAY

# Signing secret for device sign-in tokens (POST /api/v1/auth/sign-in).
EDGE_JWT_SECRET=change-me-in-production
EDGE_JWT_TTL_SECONDS=3600

# Cloud registry sync — cloud is the source of truth for the device allow-list.
# When true, the edge pulls GET /api/v1/edge/registry using gateway credentials.
# Use NODE_SEED_* only for local development when REGISTRY_SYNC_ENABLED=false.
REGISTRY_SYNC_ENABLED=false
REGISTRY_SYNC_INTERVAL_SECONDS=300
