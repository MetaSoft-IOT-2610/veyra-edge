SQLITE_DB_PATH=veyra_edge.db
API_SYNC_URL=http://localhost:8080/api/v1
CLOUD_SYNC_ENABLED=true
CLOUD_SYNC_TIMEOUT=5
CLOUD_SYNC_BATCH_SIZE=20

# Use backend as source of truth for real hardware tests.
NODE_SEED_ENABLED=false
REGISTRY_SYNC_ENABLED=true
REGISTRY_SYNC_INTERVAL_SECONDS=60
THRESHOLD_SYNC_ENABLED=true
THRESHOLD_SYNC_INTERVAL_SECONDS=60

# Embedded devices sign in to the edge using this token secret.
EDGE_JWT_SECRET=local-edge-hardware-test-secret
EDGE_JWT_TTL_SECONDS=3600

# Must match the EDGE_GATEWAY device registered in backend.
GATEWAY_DEVICE_ID=edge-local-001
GATEWAY_MAC_ADDRESS=00:11:22:33:44:55
GATEWAY_DEVICE_TYPE=EDGE_GATEWAY

# Keep 10 seconds for testing. Use 300 in the final demo/deployment.
HEART_RATE_AVERAGE_WINDOW_SECONDS=10
