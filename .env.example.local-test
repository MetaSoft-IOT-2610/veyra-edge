SQLITE_DB_PATH=veyra_edge.db
API_SYNC_URL=http://localhost:8080/api/v1
CLOUD_SYNC_ENABLED=true
CLOUD_SYNC_TIMEOUT=5
CLOUD_SYNC_BATCH_SIZE=20
NODE_SEED_ENABLED=true
NODE_SEED_PATH=nodes.seed.example.json
EDGE_JWT_SECRET=local-edge-test-secret
EDGE_JWT_TTL_SECONDS=3600
REGISTRY_SYNC_ENABLED=false
THRESHOLD_SYNC_ENABLED=false
HEART_RATE_AVERAGE_WINDOW_SECONDS=10

# Set these only when you want the edge to sync to the backend as an edge gateway.
# They must match an EDGE_GATEWAY device registered in the backend.
GATEWAY_DEVICE_ID=
GATEWAY_MAC_ADDRESS=
GATEWAY_DEVICE_TYPE=EDGE_GATEWAY
